# Build
ROS_DISTRO=humble
OM_UPSTREAM_REPO=https://github.com/NFAZ10/openmowernext.git
OM_UPSTREAM_REF=3eb9edb2f8d29f5e28fdf242de78332c192d787a

# ROS runtime
ROS_DOMAIN_ID=0
ROS_LOCALHOST_ONLY=0
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
FASTDDS_BUILTIN_TRANSPORTS=UDPv4
OM_USE_EXTERNAL_HARDWARE=true
OM_EXTERNAL_CMD_VEL_TOPIC=/cmd_vel
OM_ENABLE_FOXGLOVE=false
OM_USE_SIM_TIME=false
OM_AUTOSTART=true

# Datum and map
OM_DATUM_LAT=30.0
OM_DATUM_LONG=0.5

# MQTT and optional UI
OM_MQTT_PORT=1884
OM_MQTT_WS_PORT=9001
OM_UI_BRIDGE_WS_PORT=9002
OM_UI_BRIDGE_MODE_TOPIC=/robot_mode
OM_UI_BRIDGE_MODE_CMD_TOPIC=/robot_mode_cmd
OM_UI_BRIDGE_MOW_STRIPE_SPACING=0.4
OM_UI_BRIDGE_MOW_BOUNDARY_MARGIN=0.15
OM_UI_BRIDGE_MOW_WAYPOINT_TOLERANCE=0.35
OPENMOWER_UI_PORT=9091
OM_ZONE_EDITOR_PORT=8080

# Mower logic (mower_logic_node.py — ports OG mower_logic.cpp by Clemens Elflein)
OM_BLADE_ENABLED=true           # set false to skip mow-blade commands
OM_BLADE_TOPIC=/mower_controller/commands
OM_BLADE_SPEED=1.0              # normalised effort sent to effort controller (0.0–1.0)
OM_BATTERY_LOW_THRESHOLD=20.0   # stop mowing below this battery % and return to dock

# Optional NTRIP
OM_NTRIP_ENABLED=false
OM_NTRIP_HOSTNAME=
OM_NTRIP_PORT=2101
OM_NTRIP_ENDPOINT=
OM_NTRIP_AUTHENTICATE=false
OM_NTRIP_USER=
OM_NTRIP_PASSWORD=
OM_ZONE_EDITOR_PORT=8080
